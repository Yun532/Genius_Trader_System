# Data source: "akshare" for A-shares, "polygon" for legacy US stocks
DATA_SOURCE=akshare

# Default LLM provider for Chinese event summaries and daily/range attribution.
# Options currently supported by backend/llm.py: deepseek, openai
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional high-quality fallback / final reviewer
LLM_FALLBACK_PROVIDER=openai
LLM_FALLBACK_MODEL=gpt-5.4-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Analysis orchestration:
# - primary_with_fallback: use LLM_PROVIDER first, fallback only on failure
# - parallel_review: run primary and fallback independently, then use OpenAI if available to summarize consensus/divergence
LLM_ANALYSIS_MODE=primary_with_fallback

# LLM cost controls:
# - LLM_CACHE_ENABLED keeps daily/range/signal LLM results from being regenerated.
# - LLM_RECENT_AUTO_DAYS limits automatic LLM use to recent dates; older dates use
#   local rules unless an API request explicitly sets force_llm=true.
# - TTL settings control reusable LLM results for range attribution and signal reference.
LLM_CACHE_ENABLED=true
LLM_RECENT_AUTO_DAYS=14
LLM_DAILY_REASON_CACHE_TTL_HOURS=720
LLM_RANGE_ANALYSIS_CACHE_TTL_HOURS=336
LLM_SIGNAL_REFERENCE_CACHE_TTL_HOURS=24
LLM_STOCK_REPORT_CACHE_TTL_HOURS=168

# Optional web-search information discovery.
# The search provider discovers source-backed facts such as news, commentary,
# 龙虎榜/游资/资金流 information, and writes them into the normal event pipeline.
# DeepSeek/OpenAI analysis then works from stored events.
NEWS_WEB_SEARCH_ENABLED=false
NEWS_WEB_SEARCH_PROVIDER=openai
OPENAI_WEB_SEARCH_MODEL=gpt-5.4-mini
NEWS_WEB_SEARCH_MAX_RESULTS=8
NEWS_WEB_SEARCH_LOOKBACK_DAYS=14
NEWS_WEB_SEARCH_CACHE_TTL_HOURS=24
TAVILY_API_KEY=

# Optional local watchlist scheduler. Keep off by default; when enabled, the
# FastAPI server updates already-added stocks once per day after the configured
# China-market close time.
AUTO_SYNC_WATCHLIST=false
AUTO_SYNC_HOUR=16
AUTO_SYNC_MINUTE=45
AUTO_SYNC_STALE_DAYS=1

# Legacy/optional keys
POLYGON_API_KEY=
ANTHROPIC_API_KEY=
TUSHARE_TOKEN=
